# -------------------------------------------------------
# Paygrowa Backend — Environment Variables Reference
# Copy to .env and fill in your values
# -------------------------------------------------------

DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
SECRET_KEY=generate-a-real-key-for-production

# PostgreSQL — LOCAL
DB_NAME=paygrowa
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=5432

# PostgreSQL — SUPABASE (use instead of local block)
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=your-supabase-db-password
# DB_HOST=db.xxxxxxxxxxxxxxxxxxxx.supabase.co
# DB_PORT=5432
# DB_SSLMODE=require

# CORS (production only)
# CORS_ALLOWED_ORIGINS=https://yourfrontend.com
